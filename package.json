{
  "name": "md-jooo-sh",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "lint": "eslint .",
    "test": "node --experimental-strip-types --test src/lib/*.test.ts",
    "typecheck:worker": "tsc --noEmit -p worker/tsconfig.json",
    "worker:dev": "cf dev",
    "worker:build": "cf build; node scripts/normalize-cf-output.mjs",
    "worker:deploy": "npm run worker:build && cf deploy --prebuilt"
  },
  "dependencies": {
    "lucide-react": "^0.577.0",
    "next": "^15.5.12",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^5.20260723.1",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "autoprefixer": "^10.4.27",
    "eslint": "^9",
    "eslint-config-next": "^15.5.12",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.19",
    "typescript": "^5",
    "wrangler": "^4.113.0"
  }
}
